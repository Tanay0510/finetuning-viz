{
  "version": 2,
  "builds": [
    {
      "src": "init_db.py",
      "use": "@vercel/python"
    },
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/init-db",
      "dest": "/init_db.py"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ]
}
